generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employe {
  id                    String      @id @default(uuid())
  nom                   String
  prenom                String
  email                 String?     @unique
  telephone             String?
  pin                   String      // Code PIN pour s'authentifier
  role                  Role        @default(EMPLOYE)
  departement           String?     // Département de l'employé
  superieurHierarchique String?     // Nom du supérieur hiérarchique
  emailSuperieur        String?     // Email du supérieur hiérarchique
  actif                 Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  pointages             Pointage[]
}

model Site {
  id          String      @id @default(uuid())
  nom         String
  adresse     String
  ville       String?
  codePostal  String?
  qrCode      String      @unique // Valeur encodée dans le QR code
  qrSecret    String      // Clé secrète pour validation
  actif       Boolean     @default(true)
  latitude    Float?
  longitude   Float?
  rayonMetres Int         @default(100) // Rayon de tolérance en mètres pour le pointage
  geoRequired Boolean     @default(true) // Géolocalisation obligatoire pour ce site
  imageUrl    String?     // Nom du fichier image de fond pour ce site
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  pointages   Pointage[]
}

model Pointage {
  id          String        @id @default(uuid())
  employeId   String
  siteId      String
  type        TypePointage
  timestamp   DateTime      @default(now())
  latitude    Float?
  longitude   Float?
  employe     Employe       @relation(fields: [employeId], references: [id])
  site        Site          @relation(fields: [siteId], references: [id])
  
  @@index([employeId])
  @@index([siteId])
  @@index([timestamp])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYE
  JOURNALIER
  STAGIAIRE
}

enum TypePointage {
  ARRIVEE
  PAUSE
  REPRISE
  DEPART
}
